{
  "name": "hiredue-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @hiredue/web",
    "dev:web": "npm run dev --workspace @hiredue/web",
    "build": "npm run build --workspace @hiredue/web",
    "lint": "npm run lint --workspace @hiredue/web",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run format:check && npm run lint && npm run build"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
